  <graph edgedefault="directed">
    <node id="V84">
      <data key="d0">Certification Status</data>
      <data key="d1">Economics-Markets</data>
      <data key="d2">The eco-certification status of fishery products.</data>
      <data key="d3">no</data>
    </node>
    <node id="V78">
      <data key="d0">Consumer Preferences</data>
      <data key="d1">Economics-Markets</data>
      <data key="d2">Consumer demand patterns for seafood products.</data>
      <data key="d3">no</data>
    </node>
    <node id="V79">
      <data key="d0">Distribution Channels</data>
      <data key="d1">Economics-Markets</data>
      <data key="d2">The pathways through which products move from harvest to consumer.</data>
      <data key="d3">no</data>
    </node>
    <node id="V22">
      <data key="d0">Domestic Supply</data>
      <data key="d1">Economics-Markets</data>
      <data key="d2">The amount of seafood available for domestic consumption.</data>
      <data key="d3">no</data>
    </node>
    <node id="V38">
      <data key="d0">Economic Performance</data>
      <data key="d1">Economics-Markets</data>
      <data key="d2">The overall financial health of the fishery, including profitability and efficiency.</data>
      <data key="d3">no</data>
    </node>
    <node id="V54">
      <data key="d0">Employment</data>
      <data key="d1">Economics-Markets</data>
      <data key="d2">The number of people employed in the fishery, measured in full-time equivalents.</data>
      <data key="d3">no</data>
    </node>
    <node id="V81">
      <data key="d0">Export Markets</data>
      <data key="d1">Economics-Markets</data>
      <data key="d2">International destinations for fishery products.</data>
      <data key="d3">no</data>
    </node>
    <node id="V56">
      <data key="d0">Export Value</data>
      <data key="d1">Economics-Markets</data>
      <data key="d2">The value of fishery products sold to international markets.</data>
      <data key="d3">no</data>
    </node>
    <node id="V57">
      <data key="d0">Financial Performance</data>
      <data key="d1">Economics-Markets</data>
      <data key="d2">Various measures of economic success including profit margins and return on investment.</data>
      <data key="d3">no</data>
    </node>
    <node id="V55">
      <data key="d0">Fleet Capacity</data>
      <data key="d1">Economics-Markets</data>
      <data key="d2">The total fishing power of the fleet, including vessel numbers and characteristics.</data>
      <data key="d3">no</data>
    </node>
    <node id="V50">
      <data key="d0">Gross Value of Production</data>
      <data key="d1">Economics-Markets</data>
      <data key="d2">The total market value of fishery products at landing, approximately $86 million in 2019-20.</data>
      <data key="d3">no</data>
    </node>
    <node id="V21">
      <data key="d0">Import Volume</data>
      <data key="d1">Economics-Markets</data>
      <data key="d2">The amount of competing seafood products imported into Australia.</data>
      <data key="d3">no</data>
    </node>
    <node id="V24">
      <data key="d0">Investment Level</data>
      <data key="d1">Economics-Markets</data>
      <data key="d2">The amount of capital invested in fishing operations and infrastructure.</data>
      <data key="d3">no</data>
    </node>
    <node id="V77">
      <data key="d0">Market Competition</data>
      <data key="d1">Economics-Markets</data>
      <data key="d2">The level of competition from imports and alternative products.</data>
      <data key="d3">no</data>
    </node>
    <node id="V80">
      <data key="d0">Market Concentration</data>
      <data key="d1">Economics-Markets</data>
      <data key="d2">The degree of market power in the supply chain.</data>
      <data key="d3">no</data>
    </node>
    <node id="V14">
      <data key="d0">Market Price</data>
      <data key="d1">Economics-Markets</data>
      <data key="d2">The price received for fishery products at various market levels.</data>
      <data key="d3">no</data>
    </node>
    <node id="V51">
      <data key="d0">Net Economic Returns</data>
      <data key="d1">Economics-Markets</data>
      <data key="d2">Profits after accounting for all costs and opportunity costs of capital and labor.</data>
      <data key="d3">no</data>
    </node>
    <node id="V53">
      <data key="d0">Operating Costs</data>
      <data key="d1">Economics-Markets</data>
      <data key="d2">The costs associated with fishing operations including fuel, labor, and maintenance.</data>
      <data key="d3">no</data>
    </node>
    <node id="V85">
      <data key="d0">Price Volatility</data>
      <data key="d1">Economics-Markets</data>
      <data key="d2">The degree of price fluctuation over time.</data>
      <data key="d3">no</data>
    </node>
    <node id="V83">
      <data key="d0">Product Substitutability</data>
      <data key="d1">Economics-Markets</data>
      <data key="d2">The degree to which species can be substituted for each other.</data>
      <data key="d3">no</data>
    </node>
    <node id="V8">
      <data key="d0">Profit Level</data>
      <data key="d1">Economics-Markets</data>
      <data key="d2">The financial returns from fishing operations after accounting for costs.</data>
      <data key="d3">no</data>
    </node>
    <node id="V31">
      <data key="d0">Quota Trading</data>
      <data key="d1">Economics-Markets</data>
      <data key="d2">The buying and selling of fishing quotas between operators.</data>
      <data key="d3">no</data>
    </node>
    <node id="V23">
      <data key="d0">Quota Value</data>
      <data key="d1">Economics-Markets</data>
      <data key="d2">The market value of individual transferable quotas, reflecting expected profitability.</data>
      <data key="d3">no</data>
    </node>
    <node id="V76">
      <data key="d0">Species Price</data>
      <data key="d1">Economics-Markets</data>
      <data key="d2">The average landed value per unit weight for different species.</data>
      <data key="d3">no</data>
    </node>
    <node id="V52">
      <data key="d0">Total Factor Productivity</data>
      <data key="d1">Economics-Markets</data>
      <data key="d2">A measure of efficiency in converting inputs to outputs in the fishery.</data>
      <data key="d3">no</data>
    </node>
    <node id="V82">
      <data key="d0">Value Addition</data>
      <data key="d1">Economics-Markets</data>
      <data key="d2">Processing that increases product value.</data>
      <data key="d3">no</data>
    </node>
    <node id="V40">
      <data key="d0">Bottom Temperature</data>
      <data key="d1">Environmental-Ecosystem</data>
      <data key="d2">The temperature at the ocean floor, particularly important for demersal species.</data>
      <data key="d3">no</data>
    </node>
    <node id="V41">
      <data key="d0">Chlorophyll-a</data>
      <data key="d1">Environmental-Ecosystem</data>
      <data key="d2">A measure of phytoplankton biomass and primary productivity in the ocean.</data>
      <data key="d3">no</data>
    </node>
    <node id="V28">
      <data key="d0">Climate Change Impact</data>
      <data key="d1">Environmental-Ecosystem</data>
      <data key="d2">The effects of climate change on marine ecosystems, including warming, acidification, and changing current patterns.</data>
      <data key="d3">no</data>
    </node>
    <node id="V44">
      <data key="d0">Diatom:Dinoflagellate Ratio</data>
      <data key="d1">Environmental-Ecosystem</data>
      <data key="d2">The ratio between major phytoplankton groups, indicating food web structure.</data>
      <data key="d3">no</data>
    </node>
    <node id="V35">
      <data key="d0">Ecosystem Function</data>
      <data key="d1">Environmental-Ecosystem</data>
      <data key="d2">The processes and services provided by marine ecosystems.</data>
      <data key="d3">no</data>
    </node>
    <node id="V49">
      <data key="d0">Extreme Weather Events</data>
      <data key="d1">Environmental-Ecosystem</data>
      <data key="d2">The frequency and intensity of storms, floods, and marine heatwaves.</data>
      <data key="d3">no</data>
    </node>
    <node id="V16">
      <data key="d0">Food Web Structure</data>
      <data key="d1">Environmental-Ecosystem</data>
      <data key="d2">The network of feeding relationships between species.</data>
      <data key="d3">no</data>
    </node>
    <node id="V33">
      <data key="d0">Habitat Degradation</data>
      <data key="d1">Environmental-Ecosystem</data>
      <data key="d2">The loss or damage to marine habitats.</data>
      <data key="d3">no</data>
    </node>
    <node id="V45">
      <data key="d0">Ocean Acidification</data>
      <data key="d1">Environmental-Ecosystem</data>
      <data key="d2">The decrease in ocean pH due to CO2 absorption, affecting marine organisms.</data>
      <data key="d3">no</data>
    </node>
    <node id="V46">
      <data key="d0">Ocean Currents</data>
      <data key="d1">Environmental-Ecosystem</data>
      <data key="d2">The direction and strength of major ocean currents, including the East Australian Current.</data>
      <data key="d3">no</data>
    </node>
    <node id="V11">
      <data key="d0">Ocean Temperature</data>
      <data key="d1">Environmental-Ecosystem</data>
      <data key="d2">The temperature of ocean waters, with surface temperatures having increased by 1.2°C since 1950 in the region.</data>
      <data key="d3">no</data>
    </node>
    <node id="V48">
      <data key="d0">Oxygen Levels</data>
      <data key="d1">Environmental-Ecosystem</data>
      <data key="d2">The concentration of dissolved oxygen in seawater, declining with warming.</data>
      <data key="d3">no</data>
    </node>
    <node id="V17">
      <data key="d0">Predation Rate</data>
      <data key="d1">Environmental-Ecosystem</data>
      <data key="d2">The rate at which species are consumed by predators.</data>
      <data key="d3">no</data>
    </node>
    <node id="V30">
      <data key="d0">Primary Productivity</data>
      <data key="d1">Environmental-Ecosystem</data>
      <data key="d2">The rate of production of organic matter by phytoplankton.</data>
      <data key="d3">no</data>
    </node>
    <node id="V39">
      <data key="d0">Sea Surface Temperature</data>
      <data key="d1">Environmental-Ecosystem</data>
      <data key="d2">The temperature of the ocean surface layer, critical for species distribution and ecosystem productivity.</data>
      <data key="d3">no</data>
    </node>
    <node id="V43">
      <data key="d0">Southern Annular Mode</data>
      <data key="d1">Environmental-Ecosystem</data>
      <data key="d2">An indicator of north-south movement of westerly winds, affecting storm patterns.</data>
      <data key="d3">no</data>
    </node>
    <node id="V42">
      <data key="d0">Southern Oscillation Index</data>
      <data key="d1">Environmental-Ecosystem</data>
      <data key="d2">A measure of El Niño/La Niña development and intensity, affecting ocean conditions.</data>
      <data key="d3">no</data>
    </node>
    <node id="V47">
      <data key="d0">Upwelling Intensity</data>
      <data key="d1">Environmental-Ecosystem</data>
      <data key="d2">The strength of nutrient-rich water upwelling events.</data>
      <data key="d3">no</data>
    </node>
    <node id="V87">
      <data key="d0">Cultural Fishing Practices</data>
      <data key="d1">Indigenous</data>
      <data key="d2">Traditional methods and protocols for fishing activities.</data>
      <data key="d3">no</data>
    </node>
    <node id="V93">
      <data key="d0">Cultural Harvest Levels</data>
      <data key="d1">Indigenous</data>
      <data key="d2">The volume of catch for cultural purposes.</data>
      <data key="d3">no</data>
    </node>
    <node id="V89">
      <data key="d0">Cultural Values Mapping</data>
      <data key="d1">Indigenous</data>
      <data key="d2">Documentation of culturally significant marine areas.</data>
      <data key="d3">no</data>
    </node>
    <node id="V90">
      <data key="d0">Indigenous Economic Participation</data>
      <data key="d1">Indigenous</data>
      <data key="d2">Indigenous involvement in commercial fishing operations.</data>
      <data key="d3">no</data>
    </node>
    <node id="V88">
      <data key="d0">Indigenous Governance</data>
      <data key="d1">Indigenous</data>
      <data key="d2">Indigenous participation in fishery management decisions.</data>
      <data key="d3">no</data>
    </node>
    <node id="V95">
      <data key="d0">Indigenous Research Partnerships</data>
      <data key="d1">Indigenous</data>
      <data key="d2">Collaborative research incorporating indigenous perspectives.</data>
      <data key="d3">no</data>
    </node>
    <node id="V94">
      <data key="d0">Knowledge Transmission</data>
      <data key="d1">Indigenous</data>
      <data key="d2">The transfer of traditional knowledge between generations.</data>
      <data key="d3">no</data>
    </node>
    <node id="V92">
      <data key="d0">Sea Country Management</data>
      <data key="d1">Indigenous</data>
      <data key="d2">Indigenous approaches to marine resource stewardship.</data>
      <data key="d3">no</data>
    </node>
    <node id="V86">
      <data key="d0">Traditional Ecological Knowledge</data>
      <data key="d1">Indigenous</data>
      <data key="d2">Indigenous understanding of marine ecosystems and species.</data>
      <data key="d3">no</data>
    </node>
    <node id="V91">
      <data key="d0">Traditional Seasonal Indicators</data>
      <data key="d1">Indigenous</data>
      <data key="d2">Indigenous knowledge of environmental cues for fishing.</data>
      <data key="d3">no</data>
    </node>
    <node id="V4">
      <data key="d0">Catch Limit</data>
      <data key="d1">Management</data>
      <data key="d2">The maximum amount of fish that can be caught, set through TACs.</data>
      <data key="d3">yes</data>
    </node>
    <node id="V26">
      <data key="d0">Compliance Rate</data>
      <data key="d1">Management</data>
      <data key="d2">The degree to which fishers follow management rules.</data>
      <data key="d3">no</data>
    </node>
    <node id="V25">
      <data key="d0">Enforcement Level</data>
      <data key="d1">Management</data>
      <data key="d2">The intensity of management rule enforcement.</data>
      <data key="d3">yes</data>
    </node>
    <node id="V37">
      <data key="d0">Management Restrictions</data>
      <data key="d1">Management</data>
      <data key="d2">Various rules and regulations limiting fishing activities.</data>
      <data key="d3">yes</data>
    </node>
    <node id="V62">
      <data key="d0">Age Structure</data>
      <data key="d1">Social</data>
      <data key="d2">The age distribution of fishery participants.</data>
      <data key="d3">no</data>
    </node>
    <node id="V59">
      <data key="d0">Community Economic Dependence</data>
      <data key="d1">Social</data>
      <data key="d2">The degree to which coastal communities rely on the fishery for economic activity.</data>
      <data key="d3">no</data>
    </node>
    <node id="V64">
      <data key="d0">Community Perceptions</data>
      <data key="d1">Social</data>
      <data key="d2">Public attitudes toward the fishery and its operations.</data>
      <data key="d3">no</data>
    </node>
    <node id="V66">
      <data key="d0">Cultural Heritage Value</data>
      <data key="d1">Social</data>
      <data key="d2">The significance of fishing traditions to community identity.</data>
      <data key="d3">no</data>
    </node>
    <node id="V58">
      <data key="d0">Employment in Fishery</data>
      <data key="d1">Social</data>
      <data key="d2">The number of people directly employed in harvesting operations.</data>
      <data key="d3">no</data>
    </node>
    <node id="V63">
      <data key="d0">Fisher Wellbeing</data>
      <data key="d1">Social</data>
      <data key="d2">Measures of physical and mental health among fishing industry participants.</data>
      <data key="d3">no</data>
    </node>
    <node id="V65">
      <data key="d0">Food Security Contribution</data>
      <data key="d1">Social</data>
      <data key="d2">The fishery's contribution to regional and national food supply.</data>
      <data key="d3">no</data>
    </node>
    <node id="V61">
      <data key="d0">Gender Composition</data>
      <data key="d1">Social</data>
      <data key="d2">The gender breakdown of fishery participants.</data>
      <data key="d3">no</data>
    </node>
    <node id="V60">
      <data key="d0">Indigenous Participation</data>
      <data key="d1">Social</data>
      <data key="d2">The level of indigenous involvement in commercial fishing operations.</data>
      <data key="d3">no</data>
    </node>
    <node id="V36">
      <data key="d0">Social License</data>
      <data key="d1">Social</data>
      <data key="d2">The level of public acceptance and support for fishing operations.</data>
      <data key="d3">no</data>
    </node>
    <node id="V6">
      <data key="d0">Growth Rate</data>
      <data key="d1">Stock</data>
      <data key="d2">The rate at which individual fish increase in size, affected by food availability, temperature, and other environmental conditions.</data>
      <data key="d3">no</data>
    </node>
    <node id="V3">
      <data key="d0">Mortality Rate</data>
      <data key="d1">Stock</data>
      <data key="d2">The rate at which fish die from natural causes and fishing, including both target and non-target species mortality.</data>
      <data key="d3">no</data>
    </node>
    <node id="V2">
      <data key="d0">Recruitment Rate</data>
      <data key="d1">Stock</data>
      <data key="d2">The rate at which young fish enter the fishable population, influenced by spawning success, larval survival, and environmental conditions.</data>
      <data key="d3">no</data>
    </node>
    <node id="V32">
      <data key="d0">Spatial Stock Depletion</data>
      <data key="d1">Stock</data>
      <data key="d2">The localized reduction in fish abundance due to concentrated fishing effort in specific areas.</data>
      <data key="d3">no</data>
    </node>
    <node id="V34">
      <data key="d0">Species Abundance</data>
      <data key="d1">Stock</data>
      <data key="d2">The number or biomass of fish present in a given area, influenced by both natural and human factors.</data>
      <data key="d3">no</data>
    </node>
    <node id="V12">
      <data key="d0">Species Distribution</data>
      <data key="d1">Stock</data>
      <data key="d2">The spatial and temporal distribution of fish populations, increasingly influenced by climate change and ocean warming.</data>
      <data key="d3">no</data>
    </node>
    <node id="V1">
      <data key="d0">Stock Biomass</data>
      <data key="d1">FOCAL FACTORS</data>
      <data key="d2">The total weight or number of fish in a population, measured in tonnes or numbers. Critical for determining sustainable harvest levels and stock status.</data>
      <data key="d3">no</data>
    </node>
    <node id="V18">
      <data key="d0">Stock Recovery</data>
      <data key="d1">Stock</data>
      <data key="d2">The process of rebuilding depleted fish populations to sustainable levels, often measured against biological reference points.</data>
      <data key="d3">no</data>
    </node>
    <node id="V29">
      <data key="d0">Stock Status</data>
      <data key="d1">Stock</data>
      <data key="d2">The current condition of a fish stock relative to reference points (B20, B40, B48), indicating whether it is sustainably fished, overfished, or rebuilding.</data>
      <data key="d3">no</data>
    </node>
    <node id="V68">
      <data key="d0">Catch Per Unit Effort</data>
      <data key="d1">Technical</data>
      <data key="d2">The amount of catch obtained per unit of fishing effort, used as an index of stock abundance.</data>
      <data key="d3">no</data>
    </node>
    <node id="V7">
      <data key="d0">Catch Volume</data>
      <data key="d1">Technical</data>
      <data key="d2">The total amount of fish caught, including both retained and discarded catch, measured in tonnes.</data>
      <data key="d3">no</data>
    </node>
    <node id="V20">
      <data key="d0">Catchability</data>
      <data key="d1">Technical</data>
      <data key="d2">The ease with which fish can be caught, influenced by gear type, fish behavior, and environmental conditions.</data>
      <data key="d3">no</data>
    </node>
    <node id="V69">
      <data key="d0">Discard Rates</data>
      <data key="d1">Technical</data>
      <data key="d2">The proportion of catch returned to sea, varying by sector and target species.</data>
      <data key="d3">no</data>
    </node>
    <node id="V10">
      <data key="d0">Efficiency</data>
      <data key="d1">Technical</data>
      <data key="d2">The effectiveness of fishing operations in catching target species while minimizing bycatch and environmental impact.</data>
      <data key="d3">no</data>
    </node>
    <node id="V72">
      <data key="d0">Electronic Monitoring</data>
      <data key="d1">Technical</data>
      <data key="d2">The use of cameras and sensors to monitor fishing activities and catch composition.</data>
      <data key="d3">no</data>
    </node>
    <node id="V15">
      <data key="d0">Fishing Effort</data>
      <data key="d1">Technical</data>
      <data key="d2">The amount of fishing activity, measured in days fished, hours trawled, hook-hours, or net-hours.</data>
      <data key="d3">no</data>
    </node>
    <node id="V67">
      <data key="d0">Fishing Methods</data>
      <data key="d1">Technical</data>
      <data key="d2">The types of gear and techniques used, including trawl, Danish seine, longline, and gillnet operations.</data>
      <data key="d3">no</data>
    </node>
    <node id="V5">
      <data key="d0">Fishing Mortality</data>
      <data key="d1">Technical</data>
      <data key="d2">The proportion of fish removed by fishing activities, measured as a rate of removal from the population.</data>
      <data key="d3">no</data>
    </node>
    <node id="V13">
      <data key="d0">Fishing Patterns</data>
      <data key="d1">Technical</data>
      <data key="d2">The spatial and temporal distribution of fishing effort, influenced by regulations, weather, and fish availability.</data>
      <data key="d3">no</data>
    </node>
    <node id="V9">
      <data key="d0">Fleet Size</data>
      <data key="d1">Technical</data>
      <data key="d2">The number of active fishing vessels in the fishery, which has decreased by approximately 60% between 2000-2021.</data>
      <data key="d3">no</data>
    </node>
